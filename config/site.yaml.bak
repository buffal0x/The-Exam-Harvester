site:
  name: "Mina kurser - Omniway"
  base_url: "https://studier.nti.se/"
  login_url: "https://studier.nti.se/"
  start_url: "https://studier.nti.se/studentcourses"

auth:
  username_env: "SCRAPER_USERNAME"
  password_env: "SCRAPER_PASSWORD"
  state_file: "data/auth/playwright_state.json"

selectors:
  username: ".tab-pane input.form-control:nth-of-type(1)"
  password: ".tab-pane input.form-control:nth-of-type(2)"
  submit: ".tab-pane .col-xs-5 button"
  login_success: "small.student-id-presenter-in-summary"

crawler:
  allowed_domains:
    - "studier.nti.se"
  allowed_url_patterns:
    - "/studentcourses/3207194/"
    - "/studentcourses/3207194/exams"
    - "https://studier.nti.se/exam/"
  denied_url_patterns:
    - "/logout"
    - "/profile"
    - "/settings"
    - "/calendar"

storage:
  raw_dir: "data/raw"
  parsed_dir: "data/parsed"
  manifest_dir: "data/manifests"
